@model EventEaseWebApp.Models.Venue

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Venue</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            Venue Image
        </dt>
        <dd class = "col-sm-10">
            if (!string.IsNullOrEmpty(Model.ImageUrl)){
                <img src="Model.ImageUrl" alt=" Venue Image" width=" 250" height="250" style="object-fit:cover; border-radius:8px" />
            }
            else{
                <span>No Image Available</span>
            }
        </dd>
        
    </dl>
</div>
<div>
   
    <a asp-action="Index">Back to List</a>
</div>
